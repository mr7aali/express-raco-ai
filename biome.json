{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!node_modules",
      "!!dist",
      "!src/generated",
      "!package-lock.json",
      "!**/*.svg"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  }
}
